NODE_ENV=development
PROJECT_NAME=Qwebek
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=QwebekBot

DATABASE_PATH=./data/qwebek.sqlite

# LLM provider: openai (default) or openrouter
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# OpenRouter (used when LLM_PROVIDER=openrouter)
# Supports any model: anthropic/claude-3.5-sonnet, google/gemini-pro, openai/gpt-4o, etc.
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=

# LLM models per action
# OpenAI examples:     gpt-4o-mini, gpt-4o
# OpenRouter examples: anthropic/claude-3.5-sonnet, openai/gpt-4o-mini, google/gemini-flash-1.5
OPENAI_MODEL_POST_AD=gpt-4o-mini
OPENAI_MODEL_PERSONA=gpt-4o-mini
OPENAI_MODEL_ORGANIC_POST=gpt-4o-mini

ACCOUNT_ENCRYPTION_SECRET=change-me-min-8-chars

# Browser automation (all account registration and posting goes through Camoufox)
CAMOUFOX_HEADLESS=true

# Worker intervals
POST_WORKER_INTERVAL_MS=5000
REG_WORKER_INTERVAL_MS=30000
# Organic post: check every 1h, post at most once per 24h per account
ORGANIC_POST_CHECK_INTERVAL_MS=3600000
ORGANIC_POST_MIN_AGE_MS=86400000
