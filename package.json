{
  "name": "qwebek",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node ./build/index.js",
    "dev": "pnpm build && ts-node --esm ./src/index.ts",
    "db:migrate": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:run -d ./src/db/data-source.ts",
    "db:revert": "node --loader ts-node/esm ./node_modules/typeorm/cli.js migration:revert -d ./src/db/data-source.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/runner": "^2.0.3",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "camoufox-js": "^0.9.2",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "html-to-text": "^9.0.5",
    "pino": "^10.3.1",
    "playwright": "^1.58.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-esm": "^0.3.20"
  }
}
